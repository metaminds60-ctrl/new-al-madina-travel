{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],

  "redirects": [
    {
      "source": "https://newalmadinatravels.com/(.*)",
      "destination": "https://www.newalmadinatravels.com/$1",
      "permanent": true
    }
  ],

  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}